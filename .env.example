# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# PostgreSQL Database (Render PostgreSQL, Supabase, Neon, etc.)
# Example for Supabase: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# Example for Render: postgresql://user:password@host:5432/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/eve_skinr

# EVE Online SSO Configuration
EVE_CLIENT_ID=your_eve_client_id
EVE_CLIENT_SECRET=your_eve_client_secret
EVE_SSO_SECRET=
# The APP_URL is provided by the environment at runtime.
APP_URL=http://localhost:3000
# Callback path should be /auth/eve/callback
