{
  "rewrites": [
    { "source": "/api/skins/character/:id", "destination": "/api/skins/character.ts" },
    { "source": "/api/users/search", "destination": "/api/users/search.ts" },
    { "source": "/api/auth/eve/callback", "destination": "/api/auth/eve/callback.ts" },
    { "source": "/api/auth/eve/url", "destination": "/api/auth/eve/url.ts" },
    { "source": "/api/auth/me", "destination": "/api/auth/me.ts" },
    { "source": "/api/skins", "destination": "/api/skins.ts" },
    { "source": "/pilot/:id", "destination": "/dist/index.html" },
    { "source": "/(.*)", "destination": "/dist/$1" }
  ]
}
