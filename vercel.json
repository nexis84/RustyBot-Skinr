{
  "version": 2,
  "routes": [
    { "src": "/api/skins/character/([^/]+)", "dest": "/api/skins/character.ts?id=$1" },
    { "src": "/api/users/search", "dest": "/api/users/search.ts" },
    { "src": "/api/auth/eve/callback", "dest": "/api/auth/eve/callback.ts" },
    { "src": "/api/auth/eve/url", "dest": "/api/auth/eve/url.ts" },
    { "src": "/api/auth/me", "dest": "/api/auth/me.ts" },
    { "src": "/api/skins", "dest": "/api/skins.ts" },
    { "src": "/pilot/([^/]+)", "dest": "/dist/index.html" },
    { "src": "/(.*)", "dest": "/dist/$1" }
  ]
}
